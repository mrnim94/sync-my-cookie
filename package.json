    "postcss-flexbugs-fixes": "^4.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^6.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "tslint": "^5.12.1",
    "tslint-react": "^3.6.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.2",
    "webpack": "^5.99.9",
