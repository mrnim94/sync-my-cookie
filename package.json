    "@types/chrome": "^0.0.308",
    "@types/lodash": "^4.14.121",
    "@types/node": "^22.15.18",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@ant-design/icons": "^5.5.2",
    "antd": "^5.22.7",
    "babel-loader": "^9.2.1",
    "babel-plugin-lodash": "^3.3.4",
    "buffer": "^6.0.3",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "fs-extra": "^7.0.1",
    "html-webpack-plugin": "^5.6.0",
    "kevast": "^0.4.3",
    "kevast-chrome": "^0.0.2",
    "kevast-encrypt": "^0.1.1",
